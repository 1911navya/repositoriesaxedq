          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Set variables" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.UUID;
//-----------------
// ScanDate
//-----------------
SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss.SSS&quot;);

// Get the current time from the __time() function
long currentTimeMillis = Long.parseLong(vars.get(&quot;date&quot;));

// Shift the time by the desired amount (e.g., 1 hour)
long shiftedTimeMillis = currentTimeMillis - (24 * 60 * 60 * 1000) * Integer.parseInt(vars.get(&quot;dateCounter&quot;)); // 1 day in milliseconds

// Format the shifted time
String shiftedDateTime = sdf.format(new Date(shiftedTimeMillis));
// Store the shifted time in a variable
vars.put(&quot;scanDate&quot;, shiftedDateTime);

//-----------------
// UUID
//-----------------
vars.put(&quot;transactionId&quot;, UUID.randomUUID().toString());

log.info(&quot;Running ServerNum: ${__threadNum} DateCounter: ${vars.get(&quot;dateCounter&quot;)} TransationId: ${vars.get(&quot;transactionId&quot;)}&quot;);</stringProp>
          </JSR223PreProcessor>
