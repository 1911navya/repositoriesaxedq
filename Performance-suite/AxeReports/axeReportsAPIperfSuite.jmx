        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
          <stringProp name="scriptLanguage">java</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">public class DimensionGenerator {
    public static void main(String[] args) {
        int totalDimensions = ${numberofprojects};
        System.out.println(totalDimensions);
        // Total dimensions you want to generate
        int dimensionsPerIteration = 6; // Dimensions to generate in each iteration

        String[] allDimensions = new String[totalDimensions];

        for (int i = 0; i &lt; totalDimensions; i++) {
            allDimensions[i] = &quot;dimension&quot; + (i + 1);
        }

        for (int iteration = 1; iteration &lt;= totalDimensions / dimensionsPerIteration; iteration++) {
            System.out.println(&quot;Iteration &quot; + iteration + &quot;:&quot;);
            for (int i = (iteration - 1) * dimensionsPerIteration; i &lt; iteration * dimensionsPerIteration; i++) {
                if (i &lt; totalDimensions) {
                    System.out.println(allDimensions[i]);
                }
            }
        }
    }
}
</stringProp>
        </JSR223PreProcessor>
