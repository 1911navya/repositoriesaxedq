            <stringProp name="WebDriverSampler.script">WDS.sampleResult.sampleStart()

${__V(${IMPORTS})}


WebDriver driver = WDS.browser;
driver.get(&quot;https://qa-rocky-perf.dequemonitordev.com/worldspace/user/home&quot;);
 Thread.sleep(2000);
driver.findElement(By.linkText(&quot;Create an organization project&quot;)).click();
 //driver.get(&quot;https://qa-rocky-perf.dequemonitordev.com/worldspace/organization/projectcreate/1&quot;);
    driver.findElement(By.id(&quot;name&quot;)).click();
    driver.findElement(By.id(&quot;name&quot;)).clear();
    driver.findElement(By.id(&quot;name&quot;)).sendKeys(&quot;jmeterapi-${Counter}&quot;);
    Thread.sleep(2000);
    driver.findElement(By.id(&quot;startUrl&quot;)).click();
    driver.findElement(By.id(&quot;startUrl&quot;)).clear();
    driver.findElement(By.id(&quot;startUrl&quot;)).sendKeys(&quot;http://abcdcomputech.dequecloud.com/&quot;);
 Thread.sleep(2000);
    /////create custom scan
    driver.findElement(By.xpath(&quot;//*[@name=&apos;after_create&apos;][@value=&apos;custom-scan&apos;]&quot;)).click();
    driver.findElement(By.id(&quot;basic-scan&quot;)).click();

    
WDS.sampleResult.sampleEnd()</stringProp>
