          <stringProp name="WebDriverSampler.script">WDS.sampleResult.sampleStart()

${__V(${IMPORTS})}


WebDriver driver = WDS.browser;
driver.get(&quot;${SERVER2}&quot;);

driver.findElement(By.id(&quot;username&quot;)).sendKeys(&quot;${UserID}&quot;);
driver.findElement(By.cssSelector(&quot;.Email .Button--primary&quot;)).click();
Thread.sleep(2000);

driver.findElement(By.id(&quot;password&quot;)).sendKeys(&quot;${Password}&quot;);

driver.findElement(By.cssSelector(&quot;.Password .Button--primary&quot;)).click();
//driver.get(&quot;${SERVER2}&quot;);
///////////////////////////////////////Login
Login=driver.findElement(By.xpath(&quot;//p[contains(text(),&apos;Welcome, navya navya&apos;)]&quot;));
driver.findElement(By.xpath(&quot;//div[@id=&apos;wrap&apos;]/div/div[2]/div[2]/div/p&quot;)).click();
    Login.click();
WDS.sampleResult.sampleEnd()</stringProp>
