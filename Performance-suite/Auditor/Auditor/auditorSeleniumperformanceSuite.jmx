${__V(${IMPORTS})}

import org.junit.Test;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;

public class YourTestClassName {

    @Test
    public void testButtonClick() {
        // Set the path to your ChromeDriver executable
        System.setProperty(&quot;webdriver.chrome.driver&quot;, &quot;path/to/chromedriver&quot;);

        // Create a new instance of the Chrome driver
        WebDriver driver = new ChromeDriver();

        try {
            // Navigate to your web page
            driver.get(&quot;your_website_url&quot;);

            // Check if the &quot;Start Testing&quot; button is present
            WebElement startTestingButton = driver.findElement(By.xpath(&quot;(//a[@aria-label=&apos;Start Testing page1&apos;][normalize-space()=&apos;Start Testing&apos;])[${__counter(1,100)}]&quot;));

            if (startTestingButton.isDisplayed()) {
                // Click on &quot;Start Testing&quot; button
                startTestingButton.click();
            } else {
                // Click on &quot;Resume&quot; button if &quot;Start Testing&quot; button is not present
                WebElement resumeButton = driver.findElement(By.xpath(&quot;(//a[@aria-label=&apos;Resume page1&apos;][normalize-space()=&apos;Resume&apos;])[${__counter(1,100)}]&quot;));
                resumeButton.click();
            }
        } finally {
            // Close the browser window
            driver.quit();
        }
    }
}


WDS.sampleResult.sampleEnd()


