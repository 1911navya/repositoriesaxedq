          <stringProp name="WebDriverSampler.script">WDS.sampleResult.sampleStart()
${__V(${IMPORTS})}

WebDriver driver = WDS.browser;
 //WebDriverWait wait = new WebDriverWait(driver, 20); 
Thread.sleep(1000)
WebDriverWait wait = new WebDriverWait(driver, 500);
WebElement deleteTestunit = driver.findElement(By.xpath(&quot;//*[@id=&apos;page-form&apos;]/div[2]/div/button[2]&quot;));
deleteTestunit.click();
///Delete Test Unit
//driver.findElement(By.xpath(&quot;//*[@id=&apos;page-form&apos;]/div[2]/div/button[2]&quot;)).click();
 

 //driver.findElement(By.cssSelector(&quot;.delete .pure-button-primary&quot;)).click();
Thread.sleep(200)
 WebDriverWait wait = new WebDriverWait(driver, 20); 
String validationMessage = &quot;Page ${oldtestunits} was deleted successfully&quot;;
By validationMessageLocator = By.id(&quot;notifications&quot;);

WebElement validationElement = wait.until(ExpectedConditions.visibilityOfElementLocated(validationMessageLocator));


WDS.sampleResult.sampleEnd()
   

