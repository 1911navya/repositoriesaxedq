yesDeleteunit.click();
 //driver.findElement(By.cssSelector(&quot;.delete .pure-button-primary&quot;)).click();
Thread.sleep(200)
 WebDriverWait wait = new WebDriverWait(driver, 20); 
String validationMessage = &quot;Page ${oldtestunits} was deleted successfully&quot;;
By validationMessageLocator = By.id(&quot;notifications&quot;);

