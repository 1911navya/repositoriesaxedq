          <stringProp name="WebDriverSampler.script">WDS.sampleResult.sampleStart()
${__V(${IMPORTS})}

WebDriver driver = WDS.browser;

//driver.navigate().refresh();
//driver.findElement(By.xpath(&quot;//div[@aria-label=&apos;Components and Pages&apos;]//ul[@role=&apos;tablist&apos;]//li[2]//div&quot;)).click();
//driver.findElement(By.id(&quot;edit-unit&quot;)).click();

//Click on Edit Testunit

driver.findElement(By.id(&quot;page-name&quot;)).click();
driver.findElement(By.id(&quot;page-name&quot;)).clear();
driver.findElement(By.id(&quot;page-name&quot;)).sendKeys(&quot;${oldtestunits}&quot;);
//log.info(&quot;finaleditpage&quot;);
//Thread.sleep(250);
driver.findElement(By.id(&quot;page-url&quot;)).click();
driver.findElement(By.id(&quot;page-url&quot;)).clear();
driver.findElement(By.id(&quot;page-url&quot;)).sendKeys(&quot;${URL}&quot;);
driver.findElement(By.id(&quot;save-page&quot;)).click();

Thread.sleep(1000);
// Wait for the validation message
WebDriverWait wait = new WebDriverWait(driver, 100); 
String validationMessage = &quot;Page ${oldtestunits} was edited successfully&quot;;
By validationMessageLocator = By.id(&quot;notifications&quot;);
WebElement validationElement = wait.until(ExpectedConditions.visibilityOfElementLocated(validationMessageLocator));
//System.out.println(&quot;Validation message received: &quot; + validationElement.getText());

WDS.sampleResult.sampleEnd()
   

</stringProp>
