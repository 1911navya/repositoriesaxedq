        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="Click on Add New Test Units at Test Run Overview Page" enabled="false">
          <stringProp name="WebDriverSampler.script">${__V(${IMPORTS})}

WebDriver driver = WDS.browser;
//Thread.sleep(2000);

driver.findElement(By.cssSelector(&quot;button[data-modal-opener=&apos;page&apos;]&quot;)).click();
Thread.sleep(2000);

WebDriverWait wait = new WebDriverWait(driver, 10); // Use explicit wait with a timeout of 10 seconds

// Click and clear &quot;page-name&quot; input field
WebElement pageNameInput = driver.findElement(By.id(&quot;page-name&quot;));
//pageNameInput.click();
//pageNameInput.clear();

// Set value using JMeter counter and sendKeys
String counterValue = vars.get(&quot;__counter(1,100)&quot;);
String pageName = &quot;page&quot; + counterValue;
pageNameInput.sendKeys(pageName);

// Wait for 2 seconds
Thread.sleep(2000);

// Click, clear, and set value for &quot;page-url&quot; input field
WebElement pageUrlInput = driver.findElement(By.id(&quot;page-url&quot;));
pageUrlInput.click();
pageUrlInput.clear();
pageUrlInput.sendKeys(&quot;google.com&quot;);

// Wait for 2 seconds
Thread.sleep(2000);

// Click &quot;page-element-0&quot;
WebElement pageElement0 = driver.findElement(By.id(&quot;page-element-0&quot;));
pageElement0.click();

// Click &quot;scope-page&quot;
WebElement scopePage = driver.findElement(By.id(&quot;scope-page&quot;));
scopePage.click();

// Click &quot;save-page&quot;
WebElement savePage = driver.findElement(By.id(&quot;save-page&quot;));
savePage.click();</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">groovy</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="click on Start/Resume Testcase" enabled="false">
          <stringProp name="WebDriverSampler.script">${__V(${IMPORTS})}

WebDriver driver = WDS.browser;
Thread.sleep(2000);
