            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// Number of iterations you want for the loop
int Iterations = 500;

// Initialize an empty list to hold the pages data
def pagesList = []

// Loop to generate JSON data for each iteration
for (int i = 0; i &lt; Iterations; i++) {
    def pageData = &quot;&quot;&quot;
    {
        &quot;score&quot;: 100,
        &quot;locationUrl&quot;: &quot;http://reverb${i + 1}.com&quot;,
        &quot;locationState&quot;: &quot;${i + 1}&quot;,
        &quot;date&quot;: &quot;${__timeShift(yyyy-MM-dd HH:mm:ss.SSS,,-P${__counter(1,100)}D,,)}&quot;,
        &quot;violations&quot;: [
            {
                &quot;id&quot;: &quot;color-contrast&quot;,
                &quot;impact&quot;: &quot;serious&quot;,
                &quot;count&quot;: 18,
                &quot;tags&quot;: [
                &quot;cat.color&quot;,
                &quot;wcag2aa&quot;,
                &quot;wcag143&quot;,
                &quot;ACT&quot;
                ],
                &quot;isManual&quot;: false
            },
            {
                &quot;id&quot;: &quot;image-alt&quot;,
                &quot;impact&quot;: &quot;critical&quot;,
                &quot;count&quot;: 12,
                &quot;tags&quot;: [
                &quot;cat.text-alternatives&quot;,
                &quot;wcag2a&quot;,
                &quot;wcag111&quot;,
                &quot;section508&quot;,
                &quot;section508.22.a&quot;,
                &quot;ACT&quot;
                ],
                
                &quot;isManual&quot;: false
            }
        ]
    }
    &quot;&quot;&quot;
    // Add the page data to the list
    pagesList.add(pageData)
}

// Combine the list of pages into a single JSON array
def pagesJsonArray = &quot;[&quot; + pagesList.join(&quot;,&quot;) + &quot;],&quot;

// Store the combined JSON data in a variable (e.g., pageData)
vars.put(&quot;pageData&quot;, pagesJsonArray)
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
