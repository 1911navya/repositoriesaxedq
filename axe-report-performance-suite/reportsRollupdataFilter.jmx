          <stringProp name="WebDriverSampler.script">WDS.sampleResult.sampleStart()

${__V(${IMPORTS})}


WebDriver driver = WDS.browser;

//driver.findElement(By.xpath(&quot;//nav[@aria-label=‘Main’]//li[@class=‘pure-menu-item beef’]&quot;)).click();

